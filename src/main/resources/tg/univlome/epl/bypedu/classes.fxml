<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<BorderPane styleClass="page-root" stylesheets="@styles/accueil.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tg.univlome.epl.bypedu.Controllers.ClassesController">
    <left><fx:include source="sidebar.fxml" /></left>
    <center>
        <VBox spacing="14" styleClass="page-content">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Gestion des Classes" styleClass="page-title" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="+ Créer une classe" onAction="#ajouterClasse" styleClass="primary-button" />
                </HBox>
                <Label text="Créez vos groupes, puis affectez une matière et son enseignant référent à chaque classe." styleClass="page-subtitle" />
                <TableView fx:id="tableClasses" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNom" text="Classe" prefWidth="260" />
                        <TableColumn fx:id="colNiveau" text="Niveau" prefWidth="200" />
                        <TableColumn fx:id="colAffectations" text="Enseignements" prefWidth="190" />
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="300" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
            </children>
            <padding><Insets top="24" right="24" bottom="24" left="24" /></padding>
        </VBox>
    </center>
</BorderPane>
