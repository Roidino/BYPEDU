<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<BorderPane prefHeight="680.0" prefWidth="1000.0" stylesheets="@styles/notes.css"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tg.univlome.epl.bypedu.Controllers.BulletinsController">
   <left><fx:include source="sidebar.fxml" /></left>
   <center>
      <VBox spacing="20" style="-fx-background-color: #F8FAFC;">
         <padding><Insets bottom="30" left="35" right="35" top="30" /></padding>
         <children>

            <!-- En-tête de page -->
            <HBox alignment="CENTER_LEFT">
               <children>
                  <VBox spacing="4">
                     <children>
                        <Label styleClass="main-title" text="Bulletins scolaires">
                           <font><Font name="System Bold" size="24" /></font>
                        </Label>
                        <Label styleClass="bulletin-subtitle"
                               text="Générez et téléchargez le bulletin officiel d'un élève ou de toute une classe." />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="bulletin-badge" text="DOCUMENTS" />
               </children>
            </HBox>

            <!-- Formulaire de génération -->
            <VBox spacing="16" styleClass="bulletin-panel">
               <children>
                  <VBox spacing="2">
                     <children>
                        <Label styleClass="panel-title" text="1. Préparer le bulletin" />
                        <Label styleClass="panel-help"
                               text="Choisissez qui est concerné et pour quelle période, puis lancez le téléchargement." />
                     </children>
                  </VBox>

                  <GridPane hgap="16" vgap="6">
                     <columnConstraints>
                        <javafx.scene.layout.ColumnConstraints percentWidth="33.3" />
                        <javafx.scene.layout.ColumnConstraints percentWidth="33.3" />
                        <javafx.scene.layout.ColumnConstraints percentWidth="33.3" />
                     </columnConstraints>
                     <children>
                        <Label text="Type de bulletin" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label text="Étudiant ou classe" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Trimestre" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                        <ComboBox fx:id="comboTypeBulletin" maxWidth="Infinity" styleClass="form-input"
                                  GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ComboBox fx:id="comboCibleBulletin" maxWidth="Infinity" styleClass="form-input"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <ComboBox fx:id="comboTrimestreBulletin" maxWidth="Infinity" styleClass="form-input"
                                  GridPane.columnIndex="2" GridPane.rowIndex="1" />
                     </children>
                  </GridPane>

                  <Separator />

                  <HBox alignment="CENTER_LEFT" spacing="12">
                     <children>
                        <Label styleClass="panel-help"
                               text="Pour une classe, un bulletin distinct est généré pour chaque élève, avec son rang." />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#TelechargerBulletin"
                                styleClass="btn-download" text="⬇  Télécharger le bulletin" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox spacing="12" styleClass="bulletin-panel">
               <children>
                  <VBox spacing="2">
                     <children>
                        <Label styleClass="panel-title" text="Consulter les bulletins d'un étudiant" />
                        <Label styleClass="panel-help" text="Recherchez par nom ou prénom pour afficher tous ses bulletins et toutes ses notes." />
                     </children>
                  </VBox>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <children>
                        <TextField fx:id="txtRechercheEtudiant" prefWidth="300.0" promptText="Ex. : Kossi ou Kossi Mensah" styleClass="form-input" />
                        <Button mnemonicParsing="false" onAction="#RechercherBulletinsEtudiant" styleClass="btn-secondary" text="🔍 Rechercher" />
                        <Label fx:id="lblResultatRecherche" styleClass="panel-help" text="Aucune recherche effectuée." />
                     </children>
                  </HBox>
                  <TableView fx:id="tableBulletinsEtudiant" prefHeight="180.0" styleClass="modern-table">
                     <columns>
                        <TableColumn fx:id="colBulletinTrimestre" prefWidth="130.0" text="Trimestre" />
                        <TableColumn fx:id="colBulletinMatiere" prefWidth="180.0" text="Matière" />
                        <TableColumn fx:id="colBulletinNote" prefWidth="110.0" text="Note" />
                        <TableColumn fx:id="colBulletinClasse" prefWidth="130.0" text="Classe" />
                     </columns>
                  </TableView>
               </children>
            </VBox>

            <!-- Explication du contenu du document -->
            <HBox spacing="20">
               <children>
                  <VBox spacing="8" styleClass="bulletin-info" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="panel-title" text="2. Contenu du document" />
                        <Label wrapText="true"
                               text="Chaque bulletin reprend l'en-tête officiel, l'identité de l'élève, la liste des matières avec les notes et appréciations, la moyenne générale, la mention et — pour un bulletin de classe — le rang de l'élève, ainsi que les espaces de signature du professeur principal et du directeur." />
                     </children>
                  </VBox>

                  <VBox spacing="8" styleClass="bulletin-info" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="panel-title" text="Barème des appréciations" />
                        <Label text="16 - 20 : Excellent" />
                        <Label text="14 - 16 : Très bien" />
                        <Label text="12 - 14 : Bien" />
                        <Label text="10 - 12 : Assez bien" />
                        <Label text="8 - 10  : Passable" />
                        <Label text="0 - 8   : Insuffisant" />
                     </children>
                  </VBox>
               </children>
            </HBox>

         </children>
      </VBox>
   </center>
</BorderPane>
