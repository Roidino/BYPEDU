<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane id="root" maxHeight="-Infinity" maxWidth="-Infinity" 
            minHeight="-Infinity" minWidth="-Infinity" 
            prefHeight="400.0" prefWidth="600.0" 
            stylesheets="@styles/etudiant.css" 
            xmlns="http://javafx.com/javafx/26" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tg.univlome.epl.bypedu.Controllers.EtudiantController" >
    <left>
        <fx:include source="sidebar.fxml" fx:id="sidebar"/>
    </left>
    <center>
        <VBox id="center" BorderPane.alignment="CENTER"
              VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10"
                      prefHeight="50" VBox.vgrow="NEVER">
                    <children>
                        <Label id="titre" text="Gestion d'etudiant"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button id="ajouter" mnemonicParsing="false" text="+ Ajouter un etudiant" onAction="#ajouterEtudiant"/>
                    </children>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT" prefHeight="40" VBox.vgrow="NEVER">
                    <children>
                        <TextField fx:id="champRecherche" prefWidth="280" promptText="Rechercher un etudiant..."/>
                        <ChoiceBox fx:id="filtreClasse" prefWidth="160"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </children>
                </HBox>
                <TableView fx:id="tableau" maxWidth="Infinity" maxHeight="Infinity" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colonneNom" text="Nom" minWidth="100"/>
                        <TableColumn fx:id="colonnePrenom" text="Prénom(s)" minWidth="100"/>
                        <TableColumn fx:id="colonneAge" text="Âge" minWidth="50"/>
                        <TableColumn fx:id="colonneClasse" text="Classe" minWidth="110"/>
                        <TableColumn fx:id="colonneMoyenne" text="Moyenne" minWidth="80"/>
                        <TableColumn fx:id="colonneNumero" text="Numéro Parent" minWidth="120"/>
                        <TableColumn fx:id="colonneActions" text="Actions" minWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>