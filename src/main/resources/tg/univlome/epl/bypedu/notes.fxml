<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="620.0" prefWidth="980.0" stylesheets="@styles/notes.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tg.univlome.epl.bypedu.Controllers.NotesController">

   <left>
      <fx:include source="sidebar.fxml" />
   </left>

   <center>
      <VBox prefHeight="542.0" prefWidth="716.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="46.0">
               <children>
                  <Label styleClass="main-title" text="Gestion des Notes">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#AjouterNote" styleClass="btn-primary" text="+ Ajouter une note" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="45.0" spacing="10">
               <VBox.margin>
                  <Insets bottom="10.0" top="10.0" />
               </VBox.margin>
               <children>
                  <TextField fx:id="txtRechercher" prefHeight="30.0" prefWidth="220.0" promptText="Rechercher un étudiant..." styleClass="form-input" />
                  <Button mnemonicParsing="false" onAction="#Recherche" prefHeight="30.0" styleClass="btn-secondary" text="🔍 Rechercher" />
                  <Region HBox.hgrow="ALWAYS" />
                  <ComboBox fx:id="comboMatieres" prefHeight="30.0" prefWidth="150.0" styleClass="form-input" />
                  <ComboBox fx:id="comboClasses" prefHeight="30.0" prefWidth="160.0" promptText="Classe" styleClass="form-input" />
                  <ComboBox fx:id="comboTrimestres" prefHeight="30.0" prefWidth="150.0" styleClass="form-input" />
               </children>
            </HBox>
            <TableView fx:id="tableNotes" prefHeight="330.0" styleClass="modern-table" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colEtudiant" prefWidth="150.0" text="Étudiant" />
                  <TableColumn fx:id="colClasse" prefWidth="90.0" text="Classe" />
                  <TableColumn fx:id="colMatiere" prefWidth="120.0" text="Matière" />
                  <TableColumn fx:id="colNote" prefWidth="80.0" text="Note" />
                  <TableColumn fx:id="colTrimestre" prefWidth="110.0" text="Trimestre" />
                  <TableColumn fx:id="colActions" minWidth="165.0" maxWidth="165.0" prefWidth="165.0" text="Actions" />
               </columns>
            </TableView>

            <HBox spacing="20">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <children>
                  <VBox styleClass="summary-card, summary-card-green" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Meilleure Moyenne" styleClass="summary-label"/>
                        <Label fx:id="lblMeilleureMoyenne" text="0.00/20" styleClass="summary-value"/>
                        <Label fx:id="lblMeilleureMoyenneNom" text="—" styleClass="summary-sub"/>
                     </children>
                  </VBox>
                  <VBox styleClass="summary-card, summary-card-blue" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Moyenne de Classe" styleClass="summary-label"/>
                        <Label fx:id="lblMoyenneClasse" text="0.00/20" styleClass="summary-value"/>
                        <Label text="Toutes classes confondues" styleClass="summary-sub"/>
                     </children>
                  </VBox>
                  <VBox styleClass="summary-card, summary-card-purple" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Taux de Réussite" styleClass="summary-label"/>
                        <Label fx:id="lblTauxReussite" text="0%" styleClass="summary-value"/>
                        <Label text="Étudiants avec moyenne ≥ 10" styleClass="summary-sub"/>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
